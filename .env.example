# ============================================================
# POLO A TIERRA — Variables de entorno
# Copia este archivo como .env.local (desarrollo) y configura
# estas mismas variables en Vercel → Settings → Environment Variables
# NUNCA compartas las llaves secretas por chat o correo.
# ============================================================

# --- Bold (panel: integraciones → llaves de API) ---
BOLD_IDENTITY_KEY=
# También firma las notificaciones del webhook de Botón de pagos (no hay llave de webhook aparte)
BOLD_SECRET_KEY=

# --- Meta ---
NEXT_PUBLIC_META_PIXEL_ID=
# Token de Conversions API (Events Manager → tu pixel → Configuración → Conversions API)
META_CAPI_TOKEN=

# --- Correos (resend.com — plan gratis) ---
RESEND_API_KEY=
EMAIL_FROM=Polo a Tierra <pedidos@tapetevital.co>
EMAIL_INTERNO=tucorreo@poloatierra.co

# --- Video de ventas (ID de YouTube) ---
NEXT_PUBLIC_VSL_YOUTUBE_ID=

# --- URL base del sitio (producción) ---
NEXT_PUBLIC_BASE_URL=https://tapetevital.co

# --- Acceso al panel /gestion (usuario y contraseña) ---
ADMIN_USER=
ADMIN_PASSWORD=
